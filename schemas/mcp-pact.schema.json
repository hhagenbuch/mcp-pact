{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hhagenbuch/mcp-pact/schemas/mcp-pact.schema.json",
  "title": "mcp-pact file",
  "description": "Consumer-driven contract for MCP tool calls, version 0.1.",
  "type": "object",
  "required": ["pactVersion", "consumer", "provider", "expectations"],
  "additionalProperties": false,
  "properties": {
    "pactVersion": { "type": "string", "const": "0.1" },
    "consumer": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "expectations": {
      "type": "array",
      "items": { "$ref": "#/$defs/expectation" }
    }
  },
  "$defs": {
    "expectation": {
      "type": "object",
      "required": ["tool", "inputSchema", "interactions"],
      "additionalProperties": false,
      "properties": {
        "tool": { "type": "string", "minLength": 1 },
        "inputSchema": {
          "type": "object",
          "description": "The consumer-exercised subset of the tool's input JSON Schema."
        },
        "requiredCapabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "interactions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/interaction" }
        }
      }
    },
    "interaction": {
      "type": "object",
      "required": ["description", "input", "response"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "input": { "type": "object" },
        "response": {
          "type": "object",
          "required": ["matchers"],
          "additionalProperties": false,
          "properties": {
            "matchers": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/matcher" }
            }
          }
        }
      }
    },
    "matcher": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "pattern": "^\\$" },
        "equals": {},
        "regex": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "object", "array", "null"]
        },
        "present": { "type": "boolean" }
      },
      "oneOf": [
        { "required": ["equals"] },
        { "required": ["regex"] },
        { "required": ["type"] },
        { "required": ["present"] }
      ]
    }
  }
}
